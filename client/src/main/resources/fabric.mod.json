{
	"schemaVersion": 1,
	"id": "litemod",
	"version": "${version}",
	"name": "Litemod",
	"description": "A basic Mod for saving and loading Litematica files.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/litemod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.hackcanada.litematicmod.Litemod"
		],
		"client": [
			"com.hackcanada.litematicmod.LitemodClient"
		]
	},
	"mixins": [
		"litemod.mixins.json",
		{
			"config": "litemod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}