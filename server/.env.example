# ── LLM Provider ──
# "gemini" (default) | "openai"
LLM_PROVIDER=gemini

# Model name (optional — defaults to gemini-2.0-flash-lite or gpt-4o-mini)
# LLM_MODEL=gemini-2.0-flash-lite

# ── Gemini ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── OpenAI (or OpenAI-compatible endpoint) ──
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://your-custom-endpoint.com/v1

SERPAPI_API_KEY=your-serpapi-key-here

PERPLEXITY_API_KEY=your_pplx_key_here

MESHY_API_KEY=your_meshy_api_key_here

# ── Trellis 3D Generation (via piapi.ai) ──
PIAPI_KEY=your-piapi-api-key-here

# Max voxel size (largest dimension in blocks, default 30)
# MAX_VOXEL_SIZE=30
